# Vite environment variables
# Copy this file to .env.local or set via your hosting provider

# ==========================================
# Application Configuration
# ==========================================

# Enable maintenance mode in production build (true/false)
# Set to 'true' to show maintenance page, 'false' to show normal app
VITE_MAINTENANCE_MODE=false

# Base URL for the application (used for payment redirects)
PUBLIC_BASE_URL=http://localhost:5173

# ==========================================
# Supabase Configuration
# ==========================================

VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==========================================
# Bank of Georgia Payment Configuration
# ==========================================

# OAuth 2.0 Credentials from BOG E-Commerce Panel
# In portal they're labeled "Public Key" and "Secret Key"
BOG_CLIENT_ID=your_bog_client_id_here
BOG_CLIENT_SECRET=your_bog_client_secret_here

# BOG OAuth Token Endpoint
BOG_AUTH_URL=https://oauth2.bog.ge/auth/realms/bog/protocol/openid-connect/token

# BOG E-Commerce API Endpoint
BOG_PAYMENTS_API_URL=https://api.bog.ge/payments/v1/ecommerce/orders

# BOG Redirect URI (where users return after payment)
BOG_REDIRECT_URI=http://localhost:5173/profile?purchase=success

# BOG Callback URL (webhook endpoint - Edge Function URL)
# In production, this should be: https://your-project.supabase.co/functions/v1/bog-webhook
BOG_CALLBACK_URL=http://localhost:54321/functions/v1/bog-webhook

# ==========================================
# Telegram Bot Configuration (optional)
# ==========================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ==========================================
# Cloudflare Turnstile (CAPTCHA)
# ==========================================

# Get your site key from: https://dash.cloudflare.com/
# For testing, use: 1x00000000000000000000AA (always passes)
# For visible testing: 2x00000000000000000000AB (always blocks)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ==========================================
# Resend Email Service (Email Verification & Password Reset)
# ==========================================

# Resend API Key - Get from https://resend.com/api-keys
VITE_RESEND_API_KEY=your_resend_api_key_here

# From email address (must be verified in Resend)
RESEND_FROM_EMAIL=no-reply@smartpick.ge

# Public base URL for email links (production URL)
VITE_PUBLIC_BASE_URL=https://www.smartpick.ge

# ==========================================
# Rate Limiting (optional)
# ==========================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ==========================================
# Sentry Error Monitoring (Optional)
# ==========================================

# Sentry DSN from https://sentry.io
# Leave empty or comment out to disable Sentry
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id
